# AI-Live environment variables

# Required for transcription and Gemini-powered manual analysis.
GEMINI_API=your_gemini_api_key_here

# Optional: required only when using DeepSeek/OpenRouter helper functions.
DEEPSEEK=your_openrouter_api_key_here

# Optional model overrides.
#GEMINI_FLASH_MODEL=gemini-2.5-pro
#GEMINI_GENERAL_MODEL=gemini-2.0-flash
#GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
#DEEPSEEK_MODEL=tngtech/deepseek-r1t-chimera:free

# Optional audio configuration.
#SAMPLE_RATE=16000
#CHANNELS=1
#CHUNK_SIZE=1024

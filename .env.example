# AI-Live environment variables

# Required for Azure OpenAI analysis with gpt-5.5.
AZURE_OPENAI_ANALYSIS_API_KEY=your_gpt_5_5_api_key_here
AZURE_OPENAI_ANALYSIS_ENDPOINT=https://your-gpt-5-5-resource.openai.azure.com

# Required for Azure OpenAI auto-answer generation with gpt-5.4-nano.
AZURE_OPENAI_AUTO_ANSWER_API_KEY=your_gpt_5_4_nano_api_key_here
AZURE_OPENAI_AUTO_ANSWER_ENDPOINT=https://your-gpt-5-4-nano-resource.openai.azure.com

# Required for Azure OpenAI realtime transcription.
AZURE_OPENAI_TRANSCRIPTION_API_KEY=your_realtime_resource_api_key_here
AZURE_OPENAI_TRANSCRIPTION_ENDPOINT=https://your-realtime-resource.openai.azure.com

# Optional shared fallback. Used only when a purpose-specific key/endpoint above is omitted.
#AZURE_OPENAI_API_KEY=your_shared_azure_openai_api_key_here
#AZURE_OPENAI_ENDPOINT=https://your-shared-resource.openai.azure.com

# Optional deployment overrides. These values should match your Azure deployment names.
#AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime
#AZURE_OPENAI_TRANSCRIPTION_MODEL=whisper-1
#AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-5.5
#AZURE_OPENAI_AUTO_ANSWER_DEPLOYMENT=gpt-5.4-nano

# Optional audio configuration. Azure realtime transcription expects 24000 Hz mono PCM.
#SAMPLE_RATE=24000
#CHANNELS=1
#CHUNK_SIZE=1024
